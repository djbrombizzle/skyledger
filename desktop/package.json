{
  "name": "skyledger-desktop",
  "version": "1.1.0",
  "private": true,
  "description": "Skyledger desktop app with direct MSFS SimConnect and auto-updates.",
  "author": "Skyledger",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win nsis --x64",
    "dist:publish": "electron-builder --win nsis --x64 --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.skyledger.desktop",
    "productName": "Skyledger",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../index.html",
        "to": "app/index.html"
      },
      {
        "from": "../version.json",
        "to": "app/version.json"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "djbrombizzle",
      "repo": "skyledger"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "artifactName": "Skyledger-Setup-${version}.exe"
    }
  }
}
